	#superclass : 'GbsGemStoneError',
	#instVars : [
		'errorDescriptor'
	],
	#classVars : [
	],
	#category : 'GemStone-GBS-Converted'
}

{ #category : 'accessing' }
GbsCompilerError >> errorDescriptor
[

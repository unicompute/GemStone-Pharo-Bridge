Class {
	#name : 'GbxValueHolder',
	#superclass : 'Object',
	#instVars : [
		'value'
	],
	#category : 'GemStone-GBS-Converted',
	#package : 'GemStone-GBS-Converted'
}

{ #category : 'accessing' }
GbxValueHolder >> value [
	^ value
]

{ #category : 'accessing' }
GbxValueHolder >> value: anObject [
	value := anObject
]

{ #category : 'private support' }
GbxIconLibrary class >> methodSourceForPng: pathString selector: selector
[

	| stream |
	stream := WriteStream on: (String new: 2000).
	stream
		nextPutAll: selector;
		cr;
		cr;
		nextPutAll: '^[';
		nextPutAll: (self importMaskedImage: pathString);
		nextPutAll: '] once'.
	^stream contents
]


Extension { #name : 'GbxReplicator' }

{ #category : '*GemStone-GBS-Core' }
GbxReplicator >> manager [
	^ manager
]

{ #category : '*GemStone-GBS-Core' }
GbxReplicator >> manager: aReplicatorManager [
	manager := aReplicatorManager
]

{ #category : '*GemStone-GBS-Core' }
GbxReplicator >> session [
	^ session
]

{ #category : '*GemStone-GBS-Core' }
GbxReplicator >> session: aSession [
	session := aSession
]

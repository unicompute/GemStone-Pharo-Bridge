# Replication performance baseline thresholds.
#
# Consumed by scripts/run_replication_performance_baseline.sh. Each metric is the wall-clock time (ms) of a
# replication operation measured by the replication-live validation runner. Values are upper bounds; the lane
# also fails on a trend regression (default 35% or +50ms) vs the last entry in the trend JSONL.
# Override any value with the matching GBS_REPLICATION_PERF_* environment variable.
#
# Tuned from a real GemStone 3.7.5 run (connector/clamped sub-ms; dirty-store 14-20ms). The absolute
# ceilings below are CI-safe upper bounds (~10-30x observed to absorb shared-machine variance); the
# trend-regression check (below) is the primary fine-grained perf gate once a baseline JSONL exists.
REPLICATION_PERF_CONNECTOR_MAX_MS=500
REPLICATION_PERF_CLAMPED_MAX_MS=300
REPLICATION_PERF_DIRTY_STORE_MAX_MS=400
REPLICATION_PERF_BUSINESS_DIRTY_STORE_MAX_MS=600
REPLICATION_PERF_DOMAIN_DIRTY_STORE_MAX_MS=400

# Trend-regression detection (allowed growth vs the previous baseline entry).
REPLICATION_PERF_REGRESSION_PERCENT=35
REPLICATION_PERF_REGRESSION_MIN_DELTA_MS=50

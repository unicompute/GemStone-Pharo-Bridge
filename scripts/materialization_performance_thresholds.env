MATERIALIZATION_MIXED_COLLECTION_ARRAY_BATCHES_MAX=8
MATERIALIZATION_MIXED_DICTIONARY_PAIR_BATCHES_MAX=8
MATERIALIZATION_MIXED_SCALAR_STRING_BATCHES_MAX=8
MATERIALIZATION_MIXED_SCALAR_BYTE_ARRAY_BATCHES_MAX=8
MATERIALIZATION_SHALLOW_STRUCTURED_BYTE_FALLBACKS_MAX=0
MATERIALIZATION_MIXED_STRUCTURED_BYTE_FALLBACKS_MAX=0

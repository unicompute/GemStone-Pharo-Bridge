# Conservative live connector/clamp/dirty-store thresholds.
REPLICATION_LIVE_CONNECTOR_MAX_MS=1000
REPLICATION_LIVE_CLAMPED_MAX_MS=500
REPLICATION_LIVE_DIRTY_STORE_MAX_MS=2000

# Round-trip/transport thresholds. Clamped fetches must use GciClampedTrav and must not fall back.
REPLICATION_LIVE_CLAMPED_FETCHES_MIN=1
REPLICATION_LIVE_CLAMPED_FETCHES_MAX=3
REPLICATION_LIVE_CLAMPED_FALLBACKS_MAX=0

# Dirty writes must use the native store traversal buffer and clear export-set queues.
REPLICATION_LIVE_NATIVE_DIRTY_STORE_FLUSHES_MIN=1
REPLICATION_LIVE_DIRTY_OBJECTS_FLUSHED_MIN=3
REPLICATION_LIVE_EXPORT_SET_QUEUED_AFTER_MAX=0

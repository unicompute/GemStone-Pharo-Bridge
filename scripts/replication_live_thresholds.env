# Conservative live connector/clamp/dirty-store thresholds.
# Tuned from fallback-free local GemStone 3.7.5 runs on 2026-06-04
# where connector/clamp/dirty-store paths were single-digit to low double-digit ms.
REPLICATION_LIVE_CONNECTOR_MAX_MS=50
REPLICATION_LIVE_CLAMPED_MAX_MS=25
REPLICATION_LIVE_DIRTY_STORE_MAX_MS=75
REPLICATION_LIVE_BUSINESS_DIRTY_STORE_MAX_MS=100
REPLICATION_LIVE_DOMAIN_DIRTY_STORE_MAX_MS=75

# Round-trip/transport thresholds. Clamped fetches must use GciClampedTrav and must not fall back.
REPLICATION_LIVE_CLAMPED_FETCHES_MIN=1
REPLICATION_LIVE_CLAMPED_FETCHES_MAX=3
REPLICATION_LIVE_CLAMPED_FALLBACKS_MAX=0
REPLICATION_LIVE_CALLBACK_CLAMP_SPECS_MIN=1
REPLICATION_LIVE_PER_INSTVAR_CLAMP_ENTRIES_MIN=1
REPLICATION_LIVE_INHERITED_REPLICATION_SPEC_FIXTURES_MIN=1
REPLICATION_LIVE_CONNECTOR_PAIR_COUNT_MIN=1
REPLICATION_LIVE_DOMAIN_FIXTURE_COUNT_MIN=6
REPLICATION_LIVE_DOMAIN_PER_INSTVAR_CLAMP_ENTRIES_MIN=4
REPLICATION_LIVE_DOMAIN_CALLBACK_CLAMP_SPECS_MIN=1
REPLICATION_LIVE_DOMAIN_CALLBACK_TRAVERSAL_FIXTURES_MIN=2
REPLICATION_LIVE_DOMAIN_FAULT_LIFECYCLE_FIXTURES_MIN=1
REPLICATION_LIVE_DOMAIN_MAPPED_LIFECYCLE_FIXTURES_MIN=3
REPLICATION_LIVE_CONNECTOR_CLASS_VERSION_REPORTS_MIN=1
REPLICATION_LIVE_CONNECTOR_CLASS_VERSION_ERRORS_MAX=0
REPLICATION_LIVE_DIRTY_STORE_TRANSPORT_SUPPORTED_MIN=1
REPLICATION_LIVE_DIRTY_STORE_REPORT_SHAPE_SUPPORTED_MIN=1
REPLICATION_LIVE_DIRTY_STORE_FUNCTIONS_SUPPORTED_MIN=1
REPLICATION_LIVE_DIRTY_STORE_OOP_WIDTH_MIN=64
REPLICATION_LIVE_MATERIALIZATION_TRAVERSAL_TRANSPORT_SUPPORTED_MIN=1
REPLICATION_LIVE_MATERIALIZATION_REPORT_SHAPE_SUPPORTED_MIN=1
REPLICATION_LIVE_MATERIALIZATION_OOP_WIDTH_MIN=64
REPLICATION_LIVE_DOMAIN_DIRTY_OBJECTS_FLUSHED_MIN=6
REPLICATION_LIVE_DOMAIN_NATIVE_DIRTY_STORE_FLUSHES_MIN=3
REPLICATION_LIVE_DOMAIN_NATIVE_DIRTY_STORE_ENTRIES_MIN=6
REPLICATION_LIVE_DOMAIN_FAULT_RELEASE_QUEUED_MIN=1
REPLICATION_LIVE_DOMAIN_FAULT_RELEASE_AFTER_FAULT_MAX=0
REPLICATION_LIVE_DOMAIN_FAULT_IDENTITY_CLEARED_MIN=1
REPLICATION_LIVE_DOMAIN_FAULT_IDENTITY_RESTORED_MIN=1

# Dirty writes must use the native store traversal buffer and clear export-set queues.
REPLICATION_LIVE_NATIVE_DIRTY_STORE_FLUSHES_MIN=1
REPLICATION_LIVE_SEMANTIC_DIRTY_STORE_COMMANDS_MAX=0
REPLICATION_LIVE_SEMANTIC_DIRTY_STORE_ENTRIES_MAX=0
REPLICATION_LIVE_SEMANTIC_DICTIONARY_ENTRIES_MAX=0
REPLICATION_LIVE_SEMANTIC_SET_ENTRIES_MAX=0
REPLICATION_LIVE_SEMANTIC_BAG_ENTRIES_MAX=0
REPLICATION_LIVE_DIRTY_OBJECTS_FLUSHED_MIN=6
REPLICATION_LIVE_BUSINESS_DIRTY_OBJECTS_FLUSHED_MIN=18
REPLICATION_LIVE_BUSINESS_WRITE_FIXTURE_SIZE_MIN=18
REPLICATION_LIVE_EXPORT_SET_QUEUED_AFTER_MAX=0
REPLICATION_LIVE_BUSINESS_EXPORT_SET_QUEUED_AFTER_MAX=0
REPLICATION_LIVE_LIFECYCLE_NO_LONGER_QUEUED_MIN=1
REPLICATION_LIVE_LIFECYCLE_GCED_QUEUED_MIN=1
REPLICATION_LIVE_LIFECYCLE_NO_LONGER_ACKNOWLEDGED_MIN=1
REPLICATION_LIVE_LIFECYCLE_GCED_ACKNOWLEDGED_MIN=1

# Trend regression uses the larger of the percentage allowance or the millisecond allowance.
REPLICATION_LIVE_REGRESSION_PERCENT=100
REPLICATION_LIVE_REGRESSION_MIN_DELTA_MS=250

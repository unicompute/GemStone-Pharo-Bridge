# Conservative live connector/clamp/dirty-store thresholds.
# Tuned from local live runs where connector/clamp/dirty-store paths are single-digit ms.
REPLICATION_LIVE_CONNECTOR_MAX_MS=250
REPLICATION_LIVE_CLAMPED_MAX_MS=100
REPLICATION_LIVE_DIRTY_STORE_MAX_MS=500
REPLICATION_LIVE_BUSINESS_DIRTY_STORE_MAX_MS=500
REPLICATION_LIVE_DOMAIN_DIRTY_STORE_MAX_MS=500

# Round-trip/transport thresholds. Clamped fetches must use GciClampedTrav and must not fall back.
REPLICATION_LIVE_CLAMPED_FETCHES_MIN=1
REPLICATION_LIVE_CLAMPED_FETCHES_MAX=3
REPLICATION_LIVE_CLAMPED_FALLBACKS_MAX=0
REPLICATION_LIVE_CALLBACK_CLAMP_SPECS_MIN=1
REPLICATION_LIVE_PER_INSTVAR_CLAMP_ENTRIES_MIN=1
REPLICATION_LIVE_INHERITED_REPLICATION_SPEC_FIXTURES_MIN=1
REPLICATION_LIVE_CONNECTOR_PAIR_COUNT_MIN=1
REPLICATION_LIVE_DOMAIN_FIXTURE_COUNT_MIN=2
REPLICATION_LIVE_DOMAIN_PER_INSTVAR_CLAMP_ENTRIES_MIN=3
REPLICATION_LIVE_DOMAIN_CALLBACK_CLAMP_SPECS_MIN=1
REPLICATION_LIVE_DOMAIN_DIRTY_OBJECTS_FLUSHED_MIN=4
REPLICATION_LIVE_DOMAIN_NATIVE_DIRTY_STORE_FLUSHES_MIN=2
REPLICATION_LIVE_DOMAIN_NATIVE_DIRTY_STORE_ENTRIES_MIN=4

# Dirty writes must use the native store traversal buffer and clear export-set queues.
REPLICATION_LIVE_NATIVE_DIRTY_STORE_FLUSHES_MIN=1
REPLICATION_LIVE_SEMANTIC_DIRTY_STORE_COMMANDS_MIN=1
REPLICATION_LIVE_SEMANTIC_DIRTY_STORE_ENTRIES_MIN=3
REPLICATION_LIVE_SEMANTIC_DICTIONARY_ENTRIES_MIN=1
REPLICATION_LIVE_SEMANTIC_SET_ENTRIES_MIN=1
REPLICATION_LIVE_SEMANTIC_BAG_ENTRIES_MIN=1
REPLICATION_LIVE_DIRTY_OBJECTS_FLUSHED_MIN=6
REPLICATION_LIVE_BUSINESS_DIRTY_OBJECTS_FLUSHED_MIN=12
REPLICATION_LIVE_BUSINESS_WRITE_FIXTURE_SIZE_MIN=12
REPLICATION_LIVE_EXPORT_SET_QUEUED_AFTER_MAX=0
REPLICATION_LIVE_BUSINESS_EXPORT_SET_QUEUED_AFTER_MAX=0
REPLICATION_LIVE_LIFECYCLE_NO_LONGER_QUEUED_MIN=1
REPLICATION_LIVE_LIFECYCLE_GCED_QUEUED_MIN=1
REPLICATION_LIVE_LIFECYCLE_NO_LONGER_ACKNOWLEDGED_MIN=1
REPLICATION_LIVE_LIFECYCLE_GCED_ACKNOWLEDGED_MIN=1

# Trend regression uses the larger of the percentage allowance or the millisecond allowance.
REPLICATION_LIVE_REGRESSION_PERCENT=100
REPLICATION_LIVE_REGRESSION_MIN_DELTA_MS=250
